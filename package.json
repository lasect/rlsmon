{
	"name": "rlsmon",
	"version": "0.0.3",
	"type": "module",
	"bin": {
		"rlsmon": "./dist/index.js"
	},
	"files": [
		"dist",
		"src",
		"README.md",
		"package.json"
	],
	"scripts": {
		"dev:server": "bun run --hot src/index.ts",
		"dev:web": "vite web",
		"dev": "concurrently \"bun run dev:server\" \"bun run dev:web\"",
		"build:web": "vite build web",
		"build:server": "bun build src/index.ts --outfile dist/index.js --target bun --banner '#!/usr/bin/env bun\n'",
		"build": "bun run build:web && bun run build:server && chmod +x dist/index.js",
		"check": "biome check --write .",
		"start": "bun run src/index.ts"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.4.0",
		"@t3-oss/env-core": "^0.13.1",
		"@trpc/client": "^11.13.4",
		"@trpc/server": "^11.13.4",
		"dotenv": "^17.2.2",
		"hono": "^4.8.2",
		"postgres": "^3.4.8",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router-dom": "6",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "^1.3.4",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.0",
		"typescript": "^5",
		"vite": "^6.0.0"
	},
	"packageManager": "bun@1.3.6"
}
