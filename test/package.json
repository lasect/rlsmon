{
	"name": "@rlsmon/test",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"db:up": "docker compose -f docker/docker-compose.yml up -d",
		"db:down": "docker compose -f docker/docker-compose.yml down -v",
		"db:logs": "docker compose -f docker/docker-compose.yml logs -f",
		"db:shell": "docker exec -it rlsmon_test_db psql -U rlsmon -d rlsmon_test",
		"db:reset": "bun run db:down && bun run db:up && sleep 2 && bun run db:migrate && bun run db:seed",
		"db:migrate": "bun run src/migrate.ts",
		"db:seed": "bun run src/seed.ts",
		"db:status": "docker compose -f docker/docker-compose.yml ps",
		"db:clean": "docker compose -f docker/docker-compose.yml down -v --rmi all",
		"test:connection": "bun run src/test-connection.ts",
		"seed:minimal": "bun run src/seed.ts --minimal",
		"seed:full": "bun run src/seed.ts --full",
		"seed:enterprise": "bun run src/seed.ts --enterprise"
	},
	"dependencies": {
		"@faker-js/faker": "^9.0.0",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"@types/bun": "^1.3.4",
		"typescript": "^5"
	}
}
